		{
			"eventType": "group",
			"disabled": true,
			"title": "zSo",
			"description": "",
			"isActiveOnStart": true,
			"children": [
				{
					"eventType": "comment",
					"text": "Базовая Z-сортировка (замена EasyIsometric). Вызывается с интервалом aaa.zInt",
					"background-color": [
						0.33,
						0.73,
						0.48,
						1
					]
				},
				{
					"eventType": "block",
					"conditions": [
						{
							"id": "every-x-seconds",
							"objectClass": "System",
							"sid": 85004,
							"parameters": {
								"interval-seconds": "aaa.zInt"
							}
						}
					],
					"actions": [
						{
							"type": "script",
							"language": "javascript",
							"script": [
								"// Получаем все экземпляры семейства zSort",
								"const instances = runtime.objects.zSort.getAllInstances();",
								"",
								"// Сортируем массив по координате Y (сверху вниз)",
								"instances.sort((a, b) => a.y - b.y);",
								"",
								"// Применяем новый Z-порядок, перемещая каждый объект наверх своего слоя.",
								"// Объекты с наибольшим Y (ниже на экране) будут перемещены последними ",
								"// и окажутся поверх остальных.",
								"for (let i = 0; i < instances.length; i++) {",
								"    instances[i].moveToTop();",
								"}"
							]
						}
					],
					"sid": 85003,
					"disabled": true
				}
			],
			"sid": 85001
		},
		{
			"eventType": "group",
			"disabled": false,
			"title": "zSorting-",
			"description": "",
			"isActiveOnStart": true,
			"children": [
				{
					"eventType": "comment",
					"text": "Оптимизированная Z-сортировка. Сортирует только объекты на экране.",
					"background-color": [
						0.33,
						0.73,
						0.48,
						1
					]
				},
				{
					"eventType": "block",
					"conditions": [
						{
							"id": "compare-instance-variable",
							"objectClass": "aaa",
							"sid": 307484130288405,
							"parameters": {
								"instance-variable": "zInt",
								"comparison": 4,
								"value": "0"
							}
						},
						{
							"id": "every-x-seconds",
							"objectClass": "System",
							"sid": 842498131342126,
							"parameters": {
								"interval-seconds": "aaa.zInt"
							}
						}
					],
					"actions": [
						{
							"type": "script",
							"language": "javascript",
							"script": [
								"// Получаем все экземпляры семейства zSort",
								"const instances = runtime.objects.zSort.getAllInstances();",
								"",
								"// Фильтруем: оставляем только те, что находятся в пределах экрана (с небольшим запасом)",
								"// Используем глобальные координаты камеры и размер вьюпорта",
								"const camX = runtime.layout.scrollX;",
								"const camY = runtime.layout.scrollY;",
								"const viewW = runtime.layout.projectionWidth / 2;",
								"const viewH = runtime.layout.projectionHeight / 2;",
								"",
								"// Запас (margin) в пикселях, чтобы объекты не исчезали резко на границе",
								"const margin = 200;",
								"",
								"const left = camX - viewW - margin;",
								"const right = camX + viewW + margin;",
								"const top = camY - viewH - margin;",
								"const bottom = camY + viewH + margin;",
								"",
								"const visibleInstances = instances.filter(inst => ",
								"    inst.x >= left && inst.x <= right && inst.y >= top && inst.y <= bottom",
								");",
								"",
								"// Сортируем отфильтрованный массив по координате Y (сверху вниз)",
								"visibleInstances.sort((a, b) => a.y - b.y);",
								"",
								"// Применяем новый Z-порядок",
								"for (let i = 0; i < visibleInstances.length; i++) {",
								"    visibleInstances[i].moveToTop();",
								"}"
							]
						}
					],
					"sid": 781619836974876,
					"disabled": true
				},
