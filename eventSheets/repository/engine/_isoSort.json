{
	"name": "_isoSort",
	"events": [
		{
			"eventType": "group",
			"disabled": false,
			"title": "zSorting",
			"description": "",
			"isActiveOnStart": true,
			"children": [
				{
					"eventType": "comment",
					"text": "Оптимизированная Z-сортировка. Вынесена в функцию для вызова по таймеру, каждый тик или по сигналу.",
					"background-color": [
						0.33,
						0.73,
						0.48,
						1
					]
				},
				{
					"functionName": "zSort",
					"functionDescription": "",
					"functionCategory": "",
					"functionReturnType": "none",
					"functionCopyPicked": false,
					"functionIsAsync": false,
					"functionParameters": [],
					"eventType": "function-block",
					"conditions": [],
					"actions": [
						{
							"type": "script",
							"language": "javascript",
							"script": [
								"const instances = runtime.objects.zSort.getAllInstances();",
								"const firstInst = instances[0];",
								"if (!firstInst) return;",
								"const layer = firstInst.layer;",
								"const viewport = layer.getViewport();",
								"const padding = 240;",
								"const vLeft = viewport.left - padding;",
								"const vRight = viewport.right + padding;",
								"const vTop = viewport.top - padding;",
								"const vBottom = viewport.bottom + padding;",
								"const instancesToSort = [];",
								"for (const inst of instances) {",
								"    if (!inst.instVars.zEnable) continue;",
								"    const bbox = inst.getBoundingBox();",
								"    if (bbox.right >= vLeft && bbox.left <= vRight && bbox.bottom >= vTop && bbox.top <= vBottom) {",
								"        instancesToSort.push(inst);",
								"    }",
								"}",
								"instancesToSort.sort((a, b) => a.y - b.y);",
								"for (const inst of instancesToSort) {",
								"    inst.moveToTop();",
								"}"
							]
						}
					],
					"sid": 774359242489269
				},
