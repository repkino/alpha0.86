			"children": [
				{
					"eventType": "comment",
					"text": "Универсальная функция: выбирает случайный свободный экземпляр из банка (X < 0) по имени объекта. Возвращает UID или -1",
					"background-color": [
						0.67,
						0.98,
						0.79,
						1
					]
				},
				{
					"functionName": "pickOutside",
					"functionDescription": "",
					"functionCategory": "",
					"functionReturnType": "number",
					"functionCopyPicked": false,
					"functionIsAsync": false,
					"functionParameters": [
						{
							"name": "objectName",
							"type": "string",
							"initialValue": "",
							"comment": "",
							"sid": 740989318046744
						}
					],
					"eventType": "function-block",
					"conditions": [],
					"actions": [
						{
							"type": "script",
							"language": "javascript",
							"script": [
								"// Получаем имя объекта из параметра функции Construct 3",
								"const name = localVars.objectName;",
								"const objType = runtime.objects[name];",
								"",
								"if (objType) {",
								"    // Фильтруем экземпляры, которые находятся в банке (координата X меньше 0)",
								"    const outsideInstances = objType.getAllInstances().filter(inst => inst.x < 0);",
								"",
								"    if (outsideInstances.length > 0) {",
								"        // Выбираем случайный",
								"        const randomInst = outsideInstances[Math.floor(Math.random() * outsideInstances.length)];",
								"        // Возвращаем UID обратно в систему событий",
								"        runtime.setReturnValue(randomInst.uid);",
								"    } else {",
								"        runtime.setReturnValue(-1);",
								"    }",
								"} else {",
								"    runtime.setReturnValue(-1);",
								"}"
							]
						}
					],
					"sid": 829971593540068
				},
